# ============================================
# Org Comms PWA - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# --------------------------------------------
# Convex Configuration (Required)
# --------------------------------------------
# Get these from your Convex dashboard or run `npx convex dev`
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# --------------------------------------------
# Better Auth Configuration (Required)
# --------------------------------------------
# These are set in the Convex dashboard via `npx convex env set`
# 
# BETTER_AUTH_SECRET=$(openssl rand -base64 32)
# SITE_URL=http://localhost:3000
# SUPER_ADMIN_EMAIL=your-email@example.com

# --------------------------------------------
# Push Notifications (Optional)
# --------------------------------------------
# Generate VAPID keys with: npx web-push generate-vapid-keys
# Set both in Convex dashboard:
#   VAPID_PUBLIC_KEY=xxx
#   VAPID_PRIVATE_KEY=xxx
# And set public key here for frontend:
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# --------------------------------------------
# Email Configuration (Optional)
# --------------------------------------------
# Set in Convex dashboard:
#   RESEND_API_KEY=re_xxx
